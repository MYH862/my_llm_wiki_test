# LLM Wiki Server Configuration
# Copy this file to .env and update the values

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=llm_wiki

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-minio-password-here
MINIO_USE_SSL=false
MINIO_BUCKET_PREFIX=llm-wiki

# Qdrant Configuration
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=llm-wiki
QDRANT_VECTOR_SIZE=1536

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Optional: Tavily Web Search API
TAVILY_API_KEY=

# Optional: OpenAI API (for embeddings)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
